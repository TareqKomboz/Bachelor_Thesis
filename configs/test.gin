main.environment_type                                   = "absolute"
main.agent_name                                         = "reinforce"
main.input_dimension                                    = 2
main.function_name                                      = "Ackley"
main.number_free_parameters                             = 1
main.episode_length                                     = 10  # Reduced for MWE

# environment config
train.batch_size                                        = 4   # Reduced for MWE
train.randomize_start                                   = True

# training loop config
train.number_training_iterations                        = 10  # Reduced for MWE
train.log_interval                                      = 2
train.evaluation_interval                               = 10
train.quick_evaluation_interval                         = 5
train.checkpoint_interval                               = 10

# environment
environment_constructor.number_observations             = 1

# evaluation driver
evaluation_driver_init.n_start_pos                      = 2

# reinforce agent config
create_agent.gamma                                      = 0.99
create_agent.entropy_coefficient                        = 0.01
create_agent.value_estimation_loss_coef                 = 1.0
create_agent.fc_layer_params                            = (32, 16) # Smaller network for MWE
create_agent.value_fc_layer_params                      = (16,)
create_agent.lstm_size                                  = (16,)
create_agent.learning_rate                              = 1e-3
create_agent.use_learning_schedule                      = False
create_agent.decay_steps                                = 1000
create_agent.decay_rate                                 = 0.9

save_array_as_csv.delimiter                             = ','
load_array_from_csv.delimiter                           = ','
